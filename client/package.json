{
  "name": "tpms-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:perf": "npm run build && npm run perf:budget",
    "postinstall": "echo Skipping husky in this environment",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "perf:budget": "node ./scripts/check-chunk-budgets.mjs",
    "perf:budget:fail-test": "node ./scripts/check-chunk-budgets.mjs --max-chunk-kb=100 --max-total-js-kb=200",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "lint:encoding": "node ./scripts/check-encoding.mjs",
    "test": "cypress run",
    "test:open": "cypress open",
    "cypress:install": "cypress install"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "pdf-lib": "^1.17.1",
    "phosphor-react": "^1.4.1",
    "react": "^19.0.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "world-countries": "^5.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "cypress": "^15.10.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.6"
  }
}
